# JARVIS_HOME environment
# Copy to .env and fill in. Vite exposes VITE_* to the renderer.

# === VOICE (priority order: OpenAI → ElevenLabs → Web Speech) ===

# TIER 0 — OpenAI gpt-4o-mini-tts "shimmer": most human-sounding TTS available.
# Leave blank to skip. ~$0.015/min.
VITE_OPENAI_API_KEY=
VITE_OPENAI_TTS_MODEL=gpt-4o-mini-tts

# TIER 1 — ElevenLabs (default). Jessica is the hyper-natural v3-native voice.
# Get a key at https://elevenlabs.io — free tier works.
VITE_ELEVENLABS_API_KEY=
VITE_ELEVENLABS_VOICE_ID=
VITE_ELEVENLABS_MODEL=eleven_v3

# Clap detection sensitivity (0.0–1.0, higher = less sensitive)
VITE_CLAP_THRESHOLD=0.45

# Test mode — spacebar triggers wake
VITE_TEST_MODE=true
