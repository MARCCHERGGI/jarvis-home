node_modules/
dist/
dist-electron/
release/

# Electron-builder output dir is `release/` (see package.json `build.directories.output`).
# `build/` here used to be ignored too — kept it tracked because it now holds
# entitlements.mac.plist + icon resources required by the build pipeline.

.env
.env.local
.env.*.local

*.log
npm-debug.log*
.DS_Store
Thumbs.db

