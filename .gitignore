.idea/

# Local media — recordings and any audio Marco dropped in
public/audio/*.mp3
!public/audio/README.md

.vercel

# ── Personal / branded overrides — never ship in a public commit ──
# A user's local script with their actual market angle, follower count,
# tonight's events, etc. Public clones use GENERIC_SCRIPT in mock-data.ts.
src/services/briefing/morning.private.ts
src/services/briefing/*.private.ts
briefing-scripts/*.private.md
briefing-scripts/*.marco.md

# User's runtime config — connected services, voice ID, persona.
jarvis.config.json
jarvis.config.local.json
